# TrainLCD GraphQL endpoint. Required.
TRAINLCD_GRAPHQL_ENDPOINT=

# Vercel KV (Upstash Redis). Auto-injected by Vercel when the KV
# integration is linked. For local dev, run `vercel env pull` or fill
# the values manually. The short-URL feature (POST/GET /api/routes)
# requires these.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
